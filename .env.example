# =============================================================================
# Academic Outreach Email System - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control!
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Configuration (Optional - system works without this)
# ---------------------------------------------------------------------------
# Supported providers: openrouter, openai, anthropic
# OpenRouter is recommended - supports multiple models with one key
LLM_PROVIDER=openrouter
LLM_API_KEY=your_openrouter_api_key_here

# Model to use (can also be changed via: python main.py model --set gemini-flash)
# Options: google/gemini-2.5-flash-preview, google/gemini-2.5-pro-preview,
#          anthropic/claude-haiku-4-5-20251001, anthropic/claude-sonnet-4-6, anthropic/claude-opus-4-6
LLM_MODEL=google/gemini-2.5-flash-preview

# ---------------------------------------------------------------------------
# Email Provider (gmail, outlook, or hotmail)
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=gmail

# ---------------------------------------------------------------------------
# Gmail API (for draft creation - recommended approach)
# ---------------------------------------------------------------------------
# Download credentials.json from Google Cloud Console:
# 1. Go to https://console.cloud.google.com
# 2. Create a project
# 3. Enable Gmail API
# 4. Create OAuth 2.0 credentials (Desktop app)
# 5. Download the JSON file and save as credentials.json
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# ---------------------------------------------------------------------------
# SMTP Configuration (for direct sending - works with Gmail/Outlook/Hotmail)
# ---------------------------------------------------------------------------
# Gmail SMTP: smtp.gmail.com, port 587
# Outlook/Hotmail SMTP: smtp-mail.outlook.com, port 587
#
# For Gmail: use an App Password (not your regular password)
#   https://myaccount.google.com/apppasswords
#
# For Outlook/Hotmail: use your regular password or app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# The email address that appears in the "From" field
SENDER_EMAIL=your_email@gmail.com

# ---------------------------------------------------------------------------
# Hosted cron protection (required for Vercel automatic delivery)
# ---------------------------------------------------------------------------
# Set the same secret in Vercel. The /api/cron/auto-send route requires it.
CRON_SECRET=replace_with_a_long_random_secret

# ---------------------------------------------------------------------------
# Database and Storage
# ---------------------------------------------------------------------------
DB_PATH=data/outreach.db
LOG_DIR=logs
OUTPUT_DIR=outputs

# ---------------------------------------------------------------------------
# Turso (Cloud SQLite for Vercel deployment - optional)
# ---------------------------------------------------------------------------
# Sign up free at https://turso.tech
# Then run:
#   turso db create outreach
#   turso db show outreach --url       -> TURSO_DATABASE_URL
#   turso db tokens create outreach    -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
